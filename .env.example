# SummarIQ 환경 변수 설정
# 사용법: 이 파일을 복사하여 .env로 저장하고 값을 설정하세요
# cp .env.example .env

# ==================== 서버 설정 ====================
# 현재 IP 확인: ifconfig | grep 'inet ' | grep -v 127.0.0.1
SERVER_HOST=192.168.x.x
SERVER_PORT=8000

# 프론트엔드용 API URL (EXPO_PUBLIC_* 접두사 필수)
EXPO_PUBLIC_API_URL=http://192.168.x.x:8000

# ==================== 데이터베이스 ====================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-password
MYSQL_DATABASE=summariq

# ==================== Redis ====================
REDIS_URL=redis://localhost:6379/0

# ==================== API Keys ====================
# OpenAI (요약 생성)
OPENAI_API_KEY=your-openai-api-key

# AssemblyAI (음성 인식)
ASSEMBLY_AI_API_KEY=your-assemblyai-key

# ==================== AWS S3 ====================
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=summariq-assets
ENVIRONMENT=dev
TENANT=default

# ==================== Google Cloud ====================
GOOGLE_APPLICATION_CREDENTIALS=./summariq-credentials.json
GOOGLE_CLOUD_PROJECT_ID=your-project-id
GCS_BUCKET_NAME=summariq-audio-stt

# ==================== Notion API ====================
NOTION_CLIENT_ID=your-notion-client-id
NOTION_CLIENT_SECRET=your-notion-secret
NOTION_REDIRECT_URI=http://localhost:8000/notion/oauth/callback
NOTION_ENCRYPTION_KEY=your-32-char-base64-key

# ==================== JWT 보안 ====================
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ==================== CORS ====================
ALLOWED_ORIGINS=*

# ==================== 기타 ====================
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=sqlite:///./summariq.db
DB_PASSWORD=your-database-password
